---
import { markdownToHtml } from 'satteri'

import { HtmlExcerptDelimiter } from '../libs/markdown'

interface Props {
  content?: string
}

const { content } = Astro.props

let html = ''

if (content) {
  const result = markdownToHtml(content, { features: { frontmatter: false, gfm: true } })
  html = result.html
} else {
  html = await Astro.slots.render('default')

  const exceptDelimiterIndex = html.indexOf(HtmlExcerptDelimiter)

  if (exceptDelimiterIndex !== -1) {
    html = html.slice(0, exceptDelimiterIndex)
  }
}
---

<Fragment set:html={html} />
